# =============================================================================
# videocompress — .gitignore
# =============================================================================

# ── Python bytecode & caches ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# ── Distribution / packaging ─────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
*.whl

# ── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
.python-version

# ── IDE / editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Test / sample videos ────────────────────────────────────────────────────
# Do not commit large video files to the repository.
# If you need test fixtures, use Git LFS or download them in CI.
*.mp4
*.mkv
*.mov
*.avi
*.wmv
*.webm
*.flv
*.ts

# ── Compression output directories ──────────────────────────────────────────
output/
videocompress/output/

# ── PyInstaller build artifacts ──────────────────────────────────────────────
*.spec

# ── Temporary / log files ────────────────────────────────────────────────────
*.tmp
*.log

# ── OpenSpec working files (keep archive) ────────────────────────────────────
# openspec/ is tracked — change artifacts are managed by the openspec workflow.
*test_videos
*output
*.venv
*.ruff_cache
*.pytest_cache
*tmp
*__pycache__